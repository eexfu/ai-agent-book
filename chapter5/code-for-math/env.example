# 至少配置一个 key（优先使用 OPENAI_API_KEY）
OPENAI_API_KEY=your_openai_api_key_here
# MOONSHOT_API_KEY=your_moonshot_api_key_here   # 可选，Kimi（kimi-k3）
# ARK_API_KEY=your_ark_api_key_here             # 可选，豆包

# 通用兜底：未配置任何直连 key 时自动改走 OpenRouter；
# 另外默认模型 gpt-5.6-luna（gpt-5.x）在设置了本 key 时会优先走 OpenRouter，
# 因为直连 OpenAI 调用 gpt-5.6 需要组织实名认证。
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# 可选：切换到兼容 OpenAI 协议的服务端点
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：指定模型（默认 gpt-5.6-luna）
# MODEL=gpt-5.6-luna
